# Porta (Railway injeta automaticamente; em local use 3000)
PORT=3000

# String de conexao do Postgres (Railway preenche com a do plugin Postgres)
DATABASE_URL=postgresql://user:senha@host:5432/railway

# Token secreto para acessar o painel admin (/admin). Use algo longo e aleatorio.
ADMIN_TOKEN=troque-por-um-token-bem-grande-e-secreto

# SSL do Postgres: deixe ligado em producao. Em local sem ssl, use PGSSL=false
# PGSSL=false
